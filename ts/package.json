{
  "name": "unsnarl",
  "version": "0.2.0",
  "description": "Single-file ECMAScript / TypeScript scope and reference analyzer that emits a Mermaid flowchart and a deterministic IR (JSON).",
  "keywords": [
    "analyzer",
    "ast",
    "cli",
    "ecmascript",
    "ir",
    "mermaid",
    "scope",
    "scope-manager",
    "static-analysis",
    "typescript"
  ],
  "homepage": "https://github.com/crescware/unsnarl#readme",
  "bugs": {
    "url": "https://github.com/crescware/unsnarl/issues"
  },
  "license": "MIT",
  "author": "Crescware Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crescware/unsnarl.git"
  },
  "bin": {
    "uns": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsgo -p tsconfig.build.json",
    "check": "pnpm run check:types && pnpm run check:lint && pnpm run check:no-to-be && pnpm run check:knip && pnpm run test && pnpm run check:parity",
    "check:knip": "knip",
    "check:lint": "oxlint && oxfmt --check",
    "check:no-to-be": "pnpm --filter @unsnarl/no-to-be run exec",
    "check:parity": "vitest run --project parity",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "exec": "node dist/index.js",
    "format": "oxlint --fix && oxfmt",
    "prepublishOnly": "pnpm build",
    "test": "vitest run --project default"
  },
  "dependencies": {
    "commander": "14.0.3",
    "oxc-parser": "0.128.0",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@crescware/eslint-plugin-crescware-array-callback-arg-names": "0.0.1",
    "@types/node": "^24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260422.1",
    "eslint-scope": "9.1.2",
    "knip": "6.7.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "rimraf": "6.1.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
