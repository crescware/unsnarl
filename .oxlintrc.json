{
  "ignorePatterns": ["integration/fixtures/**"],
  "jsPlugins": [
    "./node_modules/@crescware/eslint-plugin-crescware-array-callback-arg-names/dist/index.js"
  ],
  "rules": {
    "typescript/no-explicit-any": "error",
    "eslint/no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "vitest",
            "importNames": ["it"],
            "message": "Do not import \"it()\" directly from vitest. Use \"test()\" instead."
          }
        ]
      }
    ],
    "eslint/eqeqeq": "error",
    "typescript/consistent-type-imports": "error",
    "eslint/curly": "error",
    "crescware-array-callback-arg-names/array-callback-arg-names": "error"
  }
}
