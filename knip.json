{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/index.ts",
    "src/main.ts",
    "integration/**/*.test.ts",
    "parity/**/*.test.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "integration/**/*.{ts,tsx}",
    "!integration/fixtures/**",
    "parity/**/*.{ts,tsx}"
  ],
  "ignoreDependencies": ["type-fest"]
}
