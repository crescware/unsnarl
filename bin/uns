#!/usr/bin/env node
"use strict";

const { spawnSync } = require("node:child_process");

const platform = process.platform;
const arch = process.arch;
const pkgName = `unsnarl-${platform}-${arch}`;

let binPath;
try {
  binPath = require.resolve(`${pkgName}/bin/uns`);
} catch (_err) {
  process.stderr.write(
    `unsnarl: no prebuilt binary available for ${platform}-${arch}.\n` +
      `Supported targets in this release: darwin-arm64.\n`,
  );
  process.exit(1);
}

const result = spawnSync(binPath, process.argv.slice(2), { stdio: "inherit" });

if (result.error) {
  process.stderr.write(
    `unsnarl: failed to spawn ${binPath}: ${result.error.message}\n`,
  );
  process.exit(1);
}

if (typeof result.status === "number") {
  process.exit(result.status);
}

if (result.signal) {
  process.stderr.write(`unsnarl: process terminated by signal ${result.signal}\n`);
  process.exit(1);
}

process.exit(1);
